{
  "name": "kiosk-project",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "overrides": {
    "tar": "^7.5.3",
    "@electron/rebuild": {
      "tar": "^7.5.3"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "node server/server.js",
    "dev:backend:watch": "nodemon server/server.js",
    "dev:electron": "electron .",
    "start": "concurrently --kill-others \"npm run dev\" \"npm run dev:backend\" \"wait-on tcp:3000 tcp:8080 && electron .\"",
    "start:watch": "concurrently --kill-others \"npm run dev\" \"npm run dev:backend:watch\" \"wait-on tcp:3000 tcp:8080 && electron .\"",
    "start:clean": "set NODE_OPTIONS=--trace-deprecation && concurrently --kill-others \"npm run dev\" \"npm run dev:backend\" \"wait-on tcp:3000 tcp:8080 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "clean": "rm -rf node_modules dist",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "antd": "^6.2.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "lottie-react": "^2.4.1",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "nprogress": "^0.2.0",
    "pdf-to-printer": "^5.6.1",
    "puppeteer": "^24.31.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.66.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.6",
    "react-webcam": "^7.2.0",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
    "sequelize": "^6.35.2",
    "validator": "^13.15.23",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "baseline-browser-mapping": "^2.9.16",
    "concurrently": "^8.2.2",
    "electron": "^39.2.4",
    "electron-builder": "^26.4.0",
    "nodemon": "^3.1.10",
    "vite": "^7.2.2",
    "wait-on": "^7.2.0"
  }
}
